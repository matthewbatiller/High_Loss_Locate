const map = L.map('map', {zoomControl:true}).setView([20,0], 2);

const baseLayers = {
  streets: L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors',
    maxZoom: 19
  }),
  satellite: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Tiles &copy; Esri — Source: Esri, Maxar, Earthstar Geographics, and the GIS user community',
    maxZoom: 19
  }),
  topo: L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
    attribution: 'Map data: &copy; OpenStreetMap contributors, SRTM | Map style: &copy; OpenTopoMap (CC-BY-SA)',
    maxZoom: 17
  }),
  light: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
    maxZoom: 19
  }),
  dark: L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
    maxZoom: 19
  })
};
let currentBase = baseLayers.streets.addTo(map);

const basemapSelect = document.getElementById('basemapSelect');
basemapSelect.addEventListener('change', () => {
  map.removeLayer(currentBase);
  currentBase = baseLayers[basemapSelect.value].addTo(map);
});

let lineLayerGroup = L.layerGroup().addTo(map);
let markerLayerGroup = L.layerGroup().addTo(map);
let startMarkerLayer = L.layerGroup().addTo(map);

let tracks = [];       // [{name, segments:[[[lon,lat],...], ...], lengthKm}]
let activeTrack = null;
let markerCount = 0;
let placedMarkers = []; // [{id, km, label, lat, lon, marker}] — km is distance-from-custom-start, in kilometers
let startOffsetKm = 0;   // distance (km) along the line where the custom start sits
let direction = 1;       // 1 = measure toward line end, -1 = measure back toward line start
let settingStart = false;
let placingByClick = false;

const UNITS = {
  km: {factor: 1,          label: 'km'},
  mi: {factor: 0.621371,   label: 'mi'},
  m:  {factor: 1000,       label: 'm'},
  ft: {factor: 3280.8399,  label: 'ft'}
};
let currentUnit = 'km';
function formatDist(km){
  const u = UNITS[currentUnit];
  return `${(km * u.factor).toFixed(2)} ${u.label}`;
}
function displayToKm(value){
  return value / UNITS[currentUnit].factor;
}

