function refreshStatsDisplay(){
  if (!activeTrack) return;
  const totalPoints = activeTrack.segments.reduce((sum,s) => sum + s.length, 0);
  statsEl.innerHTML = `<b>Total length:</b> ${formatDist(activeTrack.lengthKm)}<br><b>Points in line:</b> ${totalPoints}` +
    (activeTrack.segments.length > 1 ? `<br><b>Segments:</b> ${activeTrack.segments.length} (gaps are not connected)` : '');
}

function refreshLineSelectLabels(){
  Array.from(lineSelect.options).forEach((opt, i) => {
    opt.textContent = `${tracks[i].name} — ${formatDist(tracks[i].lengthKm)}`;
  });
}

dropZone.addEventListener('click', () => fileInput.click());
['dragenter','dragover'].forEach(ev => dropZone.addEventListener(ev, e => {
  e.preventDefault(); dropZone.classList.add('drag');
}));
['dragleave','drop'].forEach(ev => dropZone.addEventListener(ev, e => {
  e.preventDefault(); dropZone.classList.remove('drag');
}));
dropZone.addEventListener('drop', e => {
  const f = e.dataTransfer.files[0];
  if (f) handleFile(f);
});
fileInput.addEventListener('change', e => {
  const f = e.target.files[0];
  if (f) handleFile(f);
});

function setStatus(msg, kind){
  statusEl.textContent = msg || '';
  statusEl.className = kind || '';
}

async function handleFile(file){
  setStatus('Reading ' + file.name + ' ...');
  try {
    let kmlText;
    const lower = file.name.toLowerCase();
    if (lower.endsWith('.kmz')) {
      const buf = await file.arrayBuffer();
      const zip = await JSZip.loadAsync(buf);
      let kmlEntry = null;
      zip.forEach((path, entry) => {
        if (!kmlEntry && path.toLowerCase().endsWith('.kml')) kmlEntry = entry;
      });
      if (!kmlEntry) throw new Error('No .kml file found inside the KMZ archive.');
      kmlText = await kmlEntry.async('text');
    } else if (lower.endsWith('.kml')) {
      kmlText = await file.text();
    } else {
      throw new Error('Please provide a .kmz or .kml file.');
    }
    parseKml(kmlText);
  } catch (err) {
    console.error(err);
    setStatus(err.message || 'Could not read that file.', 'err');
  }
}

function parseKml(kmlText){
  const xml = new DOMParser().parseFromString(kmlText, 'text/xml');
  if (xml.querySelector('parsererror')) {
    setStatus('That KML/KMZ could not be parsed as XML.', 'err');
    return;
  }

  const placemarks = Array.from(xml.getElementsByTagName('Placemark'));
  const found = [];

  function coordsFromEl(coordEl){
    const raw = coordEl.textContent.trim();
    const pts = raw.split(/\s+/).filter(Boolean).map(pair => {
      const parts = pair.split(',').map(Number);
      return [parts[0], parts[1]]; // [lon, lat]
    }).filter(p => isFinite(p[0]) && isFinite(p[1]));
    return pts;
  }

  // Walk placemarks, collect any LineString coordinate arrays (incl. inside MultiGeometry)
  placemarks.forEach((pm, idx) => {
    const nameEl = pm.getElementsByTagName('name')[0];
    const name = nameEl ? nameEl.textContent.trim() : ('Track ' + (idx+1));

    const lineStrings = Array.from(pm.getElementsByTagName('LineString'));
    lineStrings.forEach((ls, j) => {
      const coordEl = ls.getElementsByTagName('coordinates')[0];
      if (!coordEl) return;
      const pts = coordsFromEl(coordEl);
      if (pts.length >= 2) {
        found.push({
          name: lineStrings.length > 1 ? `${name} (segment ${j+1})` : name,
          coords: pts
        });
      }
    });
  });

  // Fallback: any bare <LineString> not inside a Placemark we already caught
  if (found.length === 0) {
    const allLS = Array.from(xml.getElementsByTagName('LineString'));
    allLS.forEach((ls, j) => {
      const coordEl = ls.getElementsByTagName('coordinates')[0];
      if (!coordEl) return;
      const pts = coordsFromEl(coordEl);
      if (pts.length >= 2) found.push({name: 'Line ' + (j+1), coords: pts});
    });
  }

  if (found.length === 0) {
    setStatus('No line (route/track) geometry found in that file — only points or polygons, or an unsupported structure.', 'err');
    return;
  }

  lastFound = found;
  toleranceWrap.style.display = 'block';
  buildTracksFromFound(parseFloat(toleranceInput.value) || 2);
}

// --- Network-aware merging -------------------------------------------------
// Some KML/KMZ files store one path as many separate LineStrings whose endpoints
// don't land on exactly the same coordinate — often off by centimeters to a
// couple meters due to how the source GIS data was exported/rounded. Matching
// by exact coordinate string would treat those as unrelated dead ends. Instead,
// match endpoints by real-world distance (haversine, in meters) within a
// tolerance, and only merge when one candidate is clearly the match (not an
// ambiguous three-way tie, which indicates a genuine junction/branch).
function haversineMeters(a, b){
  const R = 6371000;
  const toRad = d => d * Math.PI / 180;
  const dLat = toRad(b[1] - a[1]);
  const dLon = toRad(b[0] - a[0]);
  const lat1 = toRad(a[1]), lat2 = toRad(b[1]);
  const h = Math.sin(dLat/2)**2 + Math.cos(lat1)*Math.cos(lat2)*Math.sin(dLon/2)**2;
  return 2 * R * Math.asin(Math.sqrt(h));
}

function mergeIntoChains(rawSegments, toleranceM){
  const segs = rawSegments.map(s => s.slice());
  const used = new Array(segs.length).fill(false);

  function candidatesNear(pt){
    const out = [];
    segs.forEach((seg, i) => {
      if (used[i]) return;
      const dStart = haversineMeters(pt, seg[0]);
      const dEnd = haversineMeters(pt, seg[seg.length - 1]);
      if (dStart <= toleranceM) out.push({segId: i, end: 'start', dist: dStart});
      if (dEnd <= toleranceM) out.push({segId: i, end: 'end', dist: dEnd});
    });
    out.sort((a, b) => a.dist - b.dist);
    return out;
  }

  // A match is "unambiguous" if there's only one candidate within tolerance,
  // or the nearest is clearly closer than the next (so it isn't a real fork
  // where multiple segments meet at essentially the same point).
  function bestUnambiguous(cands){
    if (cands.length === 0) return null;
    if (cands.length === 1) return cands[0];
    if (cands[1].dist > cands[0].dist * 3) return cands[0];
    return null;
  }

  const chains = [];
  for (let i = 0; i < segs.length; i++){
    if (used[i]) continue;
    used[i] = true;
    let chain = segs[i].slice();
    let progress = true;
    while (progress){
      progress = false;
      const tailMatch = bestUnambiguous(candidatesNear(chain[chain.length - 1]));
      if (tailMatch){
        const seg = segs[tailMatch.segId];
        const toAppend = tailMatch.end === 'start' ? seg.slice(1) : seg.slice(0, -1).reverse();
        chain = chain.concat(toAppend);
        used[tailMatch.segId] = true;
        progress = true;
        continue;
      }
      const headMatch = bestUnambiguous(candidatesNear(chain[0]));
      if (headMatch){
        const seg = segs[headMatch.segId];
        const toPrepend = headMatch.end === 'end' ? seg.slice(0, -1) : seg.slice(1).reverse();
        chain = toPrepend.concat(chain);
        used[headMatch.segId] = true;
        progress = true;
      }
    }
    chains.push(chain);
  }
  return chains;
}

function buildTracksFromFound(toleranceM){
  const found = lastFound;
  if (!found) return;

  const rawSegments = found.map(f => f.coords);
  const chains = mergeIntoChains(rawSegments, toleranceM);
  const networkDetected = chains.length !== found.length;

  tracks = chains.map((coords, i) => {
    const lengthKm = turf.length(turf.lineString(coords), {units:'kilometers'});
    let name;
    if (!networkDetected) {
      // No merging happened — each chain is exactly one original line, keep its name.
      name = found[i].name;
    } else {
      name = `Run ${i + 1}`;
    }
    return {name, segments: [coords], lengthKm};
  });

  // Longest runs first — usually the main trunk of a network is what people want by default.
  tracks.sort((a, b) => b.lengthKm - a.lengthKm);

  let options = tracks.map((t, i) => ({label: `${t.name} — ${formatDist(t.lengthKm)}`, idx: i}));

  lineSelect.innerHTML = '';
  options.forEach(o => {
    const opt = document.createElement('option');
    opt.value = o.idx;
    opt.textContent = o.label;
    lineSelect.appendChild(opt);
  });
  lineSelect.value = 0;

  lineSelectWrap.style.display = tracks.length > 1 ? 'block' : 'none';
  unitWrap.style.display = 'block';
  drawActiveTrack();

  markerLayerGroup.clearLayers();
  markerCount = 0;
  placedMarkers = [];
  rebuildMarkerListUI();

  divider1.style.display = 'block';
  divider2.style.display = 'block';
  distanceRow.style.display = 'flex';
  labelRow.style.display = 'block';
  placeBtn.style.display = 'block';
  placeBtn.disabled = false;
  clearBtn.style.display = 'block';
  downloadBtn.style.display = 'block';
  markerListWrap.style.display = 'block';

  const pieceWord = found.length === 1 ? 'line' : 'line pieces';
  const networkNote = networkDetected
    ? ` Merged into ${tracks.length} continuous run${tracks.length>1?'s':''} (tolerance: ${toleranceM} m).`
    : '';
  setStatus(`Loaded ${found.length} ${pieceWord}.${networkNote}`, 'ok');
}

rebuildBtn.addEventListener('click', () => {
  const tol = parseFloat(toleranceInput.value);
  if (isNaN(tol) || tol < 0) {
    setStatus('Enter a valid tolerance in meters.', 'err');
    return;
  }
  buildTracksFromFound(tol);
});

lineSelect.addEventListener('change', drawActiveTrack);

function drawActiveTrack(){
  const idx = Number(lineSelect.value || 0);
  activeTrack = tracks[idx];
  lineLayerGroup.clearLayers();
  markerLayerGroup.clearLayers();
  startMarkerLayer.clearLayers();
  markerCount = 0;
  placedMarkers = [];
  rebuildMarkerListUI();

  // Reset the custom start point / direction whenever the selected line changes —
  // an offset from the previous line wouldn't mean anything on a different one.
  startOffsetKm = 0;
  direction = 1;
  reverseDirCheckbox.checked = false;
  exitAllClickModes();
  updateStartStatus();

  // Draw each segment as its own polyline — Leaflet's multi-polyline form never
  // connects separate arrays with a line, so gaps between segments stay gaps.
  const segLatLngs = activeTrack.segments.map(seg => seg.map(c => [c[1], c[0]]));
  const poly = L.polyline(segLatLngs, {color:'#2b6a4f', weight:3, opacity:0.9});
  poly.addTo(lineLayerGroup);

  const firstSeg = segLatLngs[0];
  const lastSeg = segLatLngs[segLatLngs.length - 1];
  L.circleMarker(firstSeg[0], {radius:5, color:'#2b6a4f', fillColor:'#2b6a4f', fillOpacity:1})
    .bindTooltip('Start (0)', {permanent:false})
    .addTo(lineLayerGroup);
  L.circleMarker(lastSeg[lastSeg.length-1], {radius:5, color:'#b5561f', fillColor:'#b5561f', fillOpacity:1})
    .bindTooltip(`End (${formatDist(activeTrack.lengthKm)})`, {permanent:false})
    .addTo(lineLayerGroup);

  // Mark segment boundaries when there's more than one, so gaps in the recording are visible.
  if (segLatLngs.length > 1) {
    for (let i = 0; i < segLatLngs.length - 1; i++) {
      const endOfSeg = segLatLngs[i][segLatLngs[i].length - 1];
      const startOfNext = segLatLngs[i+1][0];
      L.circleMarker(endOfSeg, {radius:4, color:'#8a7f68', fillColor:'#fff', fillOpacity:1, weight:2})
        .bindTooltip(`Segment ${i+1} end`, {permanent:false}).addTo(lineLayerGroup);
      L.circleMarker(startOfNext, {radius:4, color:'#8a7f68', fillColor:'#fff', fillOpacity:1, weight:2})
        .bindTooltip(`Segment ${i+2} start`, {permanent:false}).addTo(lineLayerGroup);
    }
  }

  const boundsLayers = [poly];
  map.fitBounds(L.featureGroup(boundsLayers).getBounds(), {padding:[30,30]});

  statsEl.style.display = 'block';
  refreshStatsDisplay();

  startPointWrap.style.display = 'block';
  directionWrap.style.display = 'flex';
}

function updateStartStatus(){
  if (!activeTrack) return;
  if (startOffsetKm === 0) {
    startPointStatus.textContent = `Using line start (0 of ${formatDist(activeTrack.lengthKm)})`;
  } else {
    startPointStatus.textContent = `Custom start — ${formatDist(startOffsetKm)} along the line (of ${formatDist(activeTrack.lengthKm)} total)`;
  }
}

function exitAllClickModes(){
  settingStart = false;
  setStartBtn.textContent = 'Click map to set';
  setStartBtn.classList.remove('active');
  placingByClick = false;
  clickPlaceBtn.textContent = 'Click line to place marker';
  clickPlaceBtn.classList.remove('active');
  map.getContainer().style.cursor = '';
}

setStartBtn.addEventListener('click', () => {
  if (!activeTrack) return;
  const turningOn = !settingStart;
  exitAllClickModes();
  if (turningOn) {
    settingStart = true;
    setStartBtn.textContent = 'Click the line…';
    setStartBtn.classList.add('active');
    map.getContainer().style.cursor = 'crosshair';
  }
});

clickPlaceBtn.addEventListener('click', () => {
  if (!activeTrack) return;
  const turningOn = !placingByClick;
  exitAllClickModes();
  if (turningOn) {
    placingByClick = true;
    clickPlaceBtn.textContent = 'Click the line…';
    clickPlaceBtn.classList.add('active');
    map.getContainer().style.cursor = 'crosshair';
  }
});

resetStartBtn.addEventListener('click', () => {
  startOffsetKm = 0;
  startMarkerLayer.clearLayers();
  updateStartStatus();
  setStatus('');
});

reverseDirCheckbox.addEventListener('change', () => {
  direction = reverseDirCheckbox.checked ? -1 : 1;
});

map.on('click', (e) => {
  if (!activeTrack) return;
  if (!settingStart && !placingByClick) return;

  const clickPt = turf.point([e.latlng.lng, e.latlng.lat]);
  const line = turf.lineString(activeTrack.segments[0]);
  const snapped = turf.nearestPointOnLine(line, clickPt, {units:'kilometers'});
  const loc = snapped.properties.location; // absolute km along the line from its true start

  if (settingStart) {
    const [lon, lat] = snapped.geometry.coordinates;
    startOffsetKm = loc;
    startMarkerLayer.clearLayers();
    L.circleMarker([lat, lon], {radius:7, color:'#6b4fa0', fillColor:'#6b4fa0', fillOpacity:1, weight:2})
      .bindTooltip(`Custom start — ${formatDist(loc)} along line`, {permanent:false})
      .addTo(startMarkerLayer);
    updateStartStatus();
    exitAllClickModes();
    setStatus(`Start point set at ${formatDist(loc)} along the line.`, 'ok');
  } else if (placingByClick) {
    placeMarkerAt(loc, labelInput.value.trim());
  }
});

// Shared by both the typed-distance button and click-to-place: targetAbsoluteKm is the
// distance along the *whole* line from its true start (0), regardless of any custom
// start point or direction currently configured.
function placeMarkerAt(targetAbsoluteKm, label){
  if (!activeTrack) return;
  const target = Math.max(0, Math.min(targetAbsoluteKm, activeTrack.lengthKm));
  if (targetAbsoluteKm < 0) {
    setStatus('That\'s before the line\'s start — placing marker at the start instead.', 'err');
  } else if (targetAbsoluteKm > activeTrack.lengthKm) {
    setStatus(`That's beyond the line's length (${formatDist(activeTrack.lengthKm)}). Placing marker at the end instead.`, 'err');
  } else {
    setStatus('');
  }

  const [lon, lat] = pointAtDistanceAlongSegments(activeTrack.segments, target);
  const kmFromStart = (target - startOffsetKm) * direction;

  markerCount++;
  const marker = L.marker([lat, lon]);
  marker.addTo(markerLayerGroup);
  marker.openPopup();
  map.panTo([lat, lon]);

  const record = {id: markerCount, km: kmFromStart, label: label || '', lat, lon, marker};
  placedMarkers.push(record);
  updateMarkerPopup(record);
  rebuildMarkerListUI();
  labelInput.value = '';
}

function updateMarkerPopup(record){
  const title = record.label ? escapeHtml(record.label) : formatDist(record.km);
  const subtitle = record.label ? `${formatDist(record.km)} from start point<br>` : '';
  record.marker.bindPopup(`<b>${title}</b><br>${subtitle}${record.lat.toFixed(5)}, ${record.lon.toFixed(5)}`);
}

function escapeHtml(str){
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// Walks segments in order, treating gaps between them as "free" (not counted as distance),
// so the requested km only ever measures distance actually travelled along real line points.
function pointAtDistanceAlongSegments(segments, km){
  let remaining = km;
  for (let i = 0; i < segments.length; i++){
    const seg = segments[i];
    const line = turf.lineString(seg);
    const segLen = turf.length(line, {units:'kilometers'});
    const isLast = i === segments.length - 1;
    if (remaining <= segLen || isLast) {
      const pt = turf.along(line, Math.min(remaining, segLen), {units:'kilometers'});
      return pt.geometry.coordinates; // [lon, lat]
    }
    remaining -= segLen;
  }
  // Fallback (shouldn't reach here): last point of last segment
  const lastSeg = segments[segments.length - 1];
  return lastSeg[lastSeg.length - 1];
}

placeBtn.addEventListener('click', () => {
  if (!activeTrack) return;
  const enteredVal = parseFloat(distInput.value);
  if (isNaN(enteredVal) || enteredVal < 0) {
    setStatus(`Enter a valid distance in ${UNITS[currentUnit].label}.`, 'err');
    return;
  }
  const enteredKm = displayToKm(enteredVal);
  const rawTarget = startOffsetKm + direction * enteredKm;
  placeMarkerAt(rawTarget, labelInput.value.trim());
});

distInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') placeBtn.click();
});

function rebuildMarkerListUI(){
  markerList.innerHTML = '';
  if (placedMarkers.length === 0) {
    const note = document.createElement('div');
    note.className = 'empty-note';
    note.textContent = 'No markers placed yet.';
    markerList.appendChild(note);
    return;
  }
  const sorted = placedMarkers.slice().sort((a,b) => a.km - b.km);
  sorted.forEach(record => {
    const row = document.createElement('div');
    row.className = 'marker-row';
    const title = record.label ? escapeHtml(record.label) : formatDist(record.km);
    const sub = record.label ? ` (${formatDist(record.km)})` : '';
    row.innerHTML = `<span><span class="dist">${title}</span>${sub} — ${record.lat.toFixed(4)}, ${record.lon.toFixed(4)}</span>`;
    const del = document.createElement('button');
    del.textContent = '✕';
    del.title = 'Remove marker';
    del.addEventListener('click', () => {
      markerLayerGroup.removeLayer(record.marker);
      placedMarkers = placedMarkers.filter(m => m.id !== record.id);
      rebuildMarkerListUI();
    });
    row.appendChild(del);
    markerList.appendChild(row);
  });
}
rebuildMarkerListUI();

clearBtn.addEventListener('click', () => {
  markerLayerGroup.clearLayers();
  markerCount = 0;
  placedMarkers = [];
  rebuildMarkerListUI();
  setStatus('');
});

function escapeXml(str){
  return String(str).replace(/[<>&'"]/g, c => ({
    '<':'&lt;', '>':'&gt;', '&':'&amp;', "'":'&apos;', '"':'&quot;'
  }[c]));
}

function buildKmlDocument(){
  const lineCoordsText = activeTrack.segments[0]
    .map(c => `${c[0]},${c[1]},0`)
    .join(' ');

  const linePlacemark = `
    <Placemark>
      <name>${escapeXml(activeTrack.name)}</name>
      <Style><LineStyle><color>ff4f6a2b</color><width>3</width></LineStyle></Style>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>${lineCoordsText}</coordinates>
      </LineString>
    </Placemark>`;

  const sortedMarkers = placedMarkers.slice().sort((a,b) => a.km - b.km);
  const markerPlacemarks = sortedMarkers.map(m => {
    const name = m.label ? m.label : formatDist(m.km);
    const description = `${formatDist(m.km)} from start point along "${activeTrack.name}"`;
    return `
    <Placemark>
      <name>${escapeXml(name)}</name>
      <description>${escapeXml(description)}</description>
      <Point>
        <coordinates>${m.lon},${m.lat},0</coordinates>
      </Point>
    </Placemark>`;
  }).join('');

  return `<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>${escapeXml(activeTrack.name)} — distance markers</name>
${linePlacemark}
${markerPlacemarks}
  </Document>
</kml>`;
}

downloadBtn.addEventListener('click', async () => {
  if (!activeTrack) return;
  const originalText = downloadBtn.textContent;
  downloadBtn.textContent = 'Building…';
  downloadBtn.disabled = true;

  try {
    const kmlString = buildKmlDocument();
    const zip = new JSZip();
    zip.file('doc.kml', kmlString);
    const blob = await zip.generateAsync({type:'blob'});

    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${activeTrack.name.replace(/[^a-z0-9]+/gi, '_')}_markers.kmz`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 2000);

    const count = placedMarkers.length;
    setStatus(`Downloaded KMZ with the line and ${count} marker${count===1?'':'s'}.`, 'ok');
  } catch (err) {
    console.error(err);
    setStatus('Could not build the KMZ file.', 'err');
  }
  downloadBtn.textContent = originalText;
  downloadBtn.disabled = false;
});

</script>
</body>
</html>
